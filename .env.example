# Kalshi credentials
# API Key ID from your Kalshi account settings (Settings -> API Keys)
KALSHI_API_KEY_ID=

# RSA private key (PEM format) generated alongside the API key.
# Paste the full PEM block including the BEGIN/END lines, wrapped in quotes.
KALSHI_PRIVATE_KEY=

# Kalshi API base URL (production by default; swap for the demo host while testing)
# Production: https://external-api.kalshi.com/trade-api/v2
# Demo:       https://external-api.demo.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2

# Anthropic
ANTHROPIC_API_KEY=

# Risk controls
MAX_BET_USD=10
MIN_CONFIDENCE=0.70
MAX_OPEN_POSITIONS=5
SCAN_INTERVAL_SECONDS=60
DAILY_LOSS_LIMIT_USD=50

# Number of concurrent order-book lookups during market scanning
ORDER_BOOK_FETCH_WORKERS=20

# Safety switch - set to false to place real orders
DRY_RUN=true

# Environment
ENV=development
LOG_LEVEL=INFO
